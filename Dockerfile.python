FROM public.ecr.aws/docker/library/python:3.11-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Install Python dependencies that the SDK needs
RUN python -m pip install --no-cache-dir "requests>=2.28.0" "aiohttp>=3.8.0"

# Copy Python SDK (without trying to install via setup.py)
COPY sdk/python/ sdk/python/

# Set Python path for SDK access
ENV PYTHONPATH=/app/sdk/python
ENV PYTHONUNBUFFERED=1

# No default CMD - docker-compose must specify the command
